{
  "name": "sf-mock-services",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local mock servers for Scripture Forge's external dependencies: Auth0, Paratext Registry, Paratext send/receive archives, and the DBL resources adapter. See README.md.",
  "bin": {
    "sf-mock": "client/cli.mjs"
  },
  "scripts": {
    "start": "tsx src/server.ts",
    "serval": "scripts/run-serval.sh",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.17.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
