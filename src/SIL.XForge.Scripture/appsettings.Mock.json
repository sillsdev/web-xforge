{
  // Loaded (last, overriding appsettings.user.json) when SF_MOCK_SERVICES=true.
  // Points all external services at the local mock-services process (src/MockServices).
  // Nothing in this file is secret; the client IDs and secret exist only in the mock world.
  "Auth": {
    "Domain": "http://localhost:5100/auth0",
    "Audience": "https://scriptureforge.org/",
    "ManagementAudience": "http://localhost:5100/auth0/api/v2/",
    "FrontendClientId": "sf-mock-frontend-client",
    "BackendClientId": "sf-mock-backend-client",
    "BackendClientSecret": "sf-mock-backend-secret"
  },
  "Paratext": {
    "SendReceiveServerUri": "http://localhost:5100/archives/send_receive_server/api94/",
    "RegistryServerUri": "http://localhost:5100/registry",
    "DblServerUri": "http://localhost:5100/dbl/",
    "MockServicesEnabled": true
  },
  "DataAccess": {
    "ConnectionString": "mongodb://localhost:27017",
    // Separate databases from real dev data. The mock world has an entirely different set of
    // users and projects (keyed off the fake Auth0 / Paratext ids), so it must not share the
    // real "xforge" / "sf_jobs" databases. This name also flows to the realtime (ShareDB)
    // server via RealtimeService, so switching SF_MOCK_SERVICES on/off cleanly switches the
    // whole data universe with no cross-contamination.
    "MongoDatabaseName": "xforge_mock",
    "JobDatabaseName": "sf_mock_jobs"
  },
  "NgServeScript": "start:mock",
  // A real Serval (with its in-process Echo engine) run locally from source — see
  // src/MockServices/README.md "Local Serval". Tokens come from the fake Auth0; Serval itself
  // validates them over the mock's HTTPS listener (its authority scheme is hardcoded https).
  "Serval": {
    "ApiServer": "http://localhost:5150",
    "Audience": "https://serval-api.org/",
    "ClientId": "sf-mock-serval-client",
    "ClientSecret": "sf-mock-serval-secret",
    "TokenUrl": "http://localhost:5100/auth0/oauth/token"
  },
  "Site": {
    "SendEmail": "false"
  }
}
