    "@eslint/js": "^9.39.2",
    "@types/ajv-bsontype": "^1.0.4",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/lodash-es": "^4.17.7",
